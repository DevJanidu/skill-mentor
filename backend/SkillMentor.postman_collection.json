          }
        },
        {
          "name": "Cancel Session (Student)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}", "cancel"]
            },
            "description": "Soft-cancel a PENDING session. Role: ADMIN | STUDENT."
          }
        },
        {
          "name": "Submit Review",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"review\": \"Excellent session! Very helpful.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}/review",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}", "review"]
            },
            "description": "Session must be COMPLETED. Rating 1-5. Role: ADMIN | STUDENT."
          }
        }
      ]
    },
    {
      "name": "Sessions  Lifecycle (Mentor/Admin)",
      "item": [
        {
          "name": "Approve Session + Set Meeting Link",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"meetingLink\": \"https://meet.google.com/abc-defg-hij\",\n  \"meetingPassword\": \"optional-password\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}", "approve"]
            },
            "description": "Approve a pending payment and attach a meeting link. Status -> SCHEDULED. Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Reject Session",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Payment receipt is invalid or unclear.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}/reject",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}", "reject"]
            },
            "description": "Reject a pending payment with a reason. Status -> CANCELED. Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Start Session",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}/start",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}", "start"]
            },
            "description": "Mark session as STARTED. Status must be SCHEDULED. Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Complete Session",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionNotes\": \"Great session! Student covered all topics.\"\n}",
