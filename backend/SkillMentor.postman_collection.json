{
  "info": {
    "_postman_id": "skillmentor-v4",
    "name": "SkillMentor API",
    "description": "Complete SkillMentor REST API collection. Copy your JWT from /dev/token (admin) or the Dashboard JWT card, paste into the `clerk_token` environment variable, then run any request.\n\nRole legend:\n Any authenticated = any signed-in user\n STUDENT / MENTOR / ADMIN = that role required",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{clerk_token}}", "type": "string" }]
  },
  "variable": [{ "key": "base_url", "value": "http://localhost:8080" }],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Sync Current User",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/sync",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "sync"]
            },
            "description": "Sync the JWT user into the DB. Call after every login. Role: any authenticated."
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/me",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "me"]
            },
            "description": "Returns the DB user for the current JWT. Role: any authenticated."
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Role: ADMIN."
          }
        },
        {
          "name": "Get User by Clerk ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{clerk_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{clerk_id}}"]
            },
            "description": "Role: ADMIN."
          }
        },
        {
          "name": "Delete User",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/users/{{clerk_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "{{clerk_id}}"]
            },
            "description": "Role: ADMIN."
          }
        }
      ]
    },
    {
      "name": "Onboarding",
      "item": [
        {
          "name": "Complete Onboarding",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"STUDENT\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/onboarding/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "onboarding", "complete"]
            },
            "description": "Select a role for the current user. Values: STUDENT | MENTOR. Role: any authenticated."
          }
        },
        {
          "name": "Get Onboarding Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/onboarding/status",
              "host": ["{{base_url}}"],
              "path": ["api", "onboarding", "status"]
            },
            "description": "Check if current user has completed onboarding. Role: any authenticated."
          }
        },
        {
          "name": "Get My Roles",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/onboarding/my-roles",
              "host": ["{{base_url}}"],
              "path": ["api", "onboarding", "my-roles"]
            },
            "description": "Returns roles from Clerk for current user. Role: any authenticated."
          }
        },
        {
          "name": "Update User Roles (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clerkId\": \"{{clerk_id}}\",\n  \"roles\": [\"ADMIN\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/onboarding/roles",
              "host": ["{{base_url}}"],
              "path": ["api", "onboarding", "roles"]
            },
            "description": "Override roles for any user. Role: ADMIN."
          }
        }
      ]
    },
    {
      "name": "Mentors",
      "item": [
        {
          "name": "Get All Mentors",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/mentors",
              "host": ["{{base_url}}"],
              "path": ["api", "mentors"]
            },
            "description": "Public - no auth required."
          }
        },
        {
          "name": "Search Mentors (paged)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/mentors/search?name={{mentor_search_name}}&profession={{mentor_search_profession}}&page=0&size=10&sort=id,asc",
              "host": ["{{base_url}}"],
              "path": ["api", "mentors", "search"],
              "query": [
                { "key": "name", "value": "{{mentor_search_name}}" },
                {
                  "key": "profession",
                  "value": "{{mentor_search_profession}}"
                },
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "sort", "value": "id,asc" }
              ]
            },
            "description": "Public - paginated mentor search by name/profession."
          }
        },
        {
          "name": "Get Mentor by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/mentors/{{mentor_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "mentors", "{{mentor_id}}"]
            },
            "description": "Public - no auth required."
