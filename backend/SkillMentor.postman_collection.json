            "description": "Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Delete Mentor",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/mentors/{{mentor_id}}",
