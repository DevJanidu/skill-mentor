    {
      "name": "Sessions  CRUD (Mentor/Admin)",
      "item": [
        {
          "name": "Get All Sessions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions"]
            },
            "description": "Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Get Session by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}"]
            },
            "description": "Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Create Session (Mentor)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"studentIds\": [{{student_id}}],\n  \"mentorId\": {{mentor_id}},\n  \"subjectId\": {{subject_id}},\n  \"sessionType\": \"INDIVIDUAL\",\n  \"maxParticipants\": 1,\n  \"sessionAt\": \"2026-06-01T10:00:00.000Z\",\n  \"durationMinutes\": 60\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions"]
            },
            "description": "Mentor manually creates a session. sessionType: INDIVIDUAL | GROUP. Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Update Session",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionAt\": \"2026-06-02T10:00:00.000Z\",\n  \"durationMinutes\": 90,\n  \"sessionStatus\": \"SCHEDULED\",\n  \"sessionType\": \"INDIVIDUAL\",\n  \"maxParticipants\": 1,\n  \"meetingLink\": \"https://meet.google.com/xxx-yyyy-zzz\",\n  \"sessionNotes\": \"Updated notes.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}"]
            },
            "description": "Full update. sessionStatus: PENDING | SCHEDULED | STARTED | COMPLETED | CANCELED. Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Delete Session",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}"]
            },
            "description": "Hard delete. Role: ADMIN | MENTOR."
          }
        },
        {
          "name": "Get Sessions by Mentor",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/mentor/{{mentor_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "mentor", "{{mentor_id}}"]
            },
            "description": "Role: ADMIN | MENTOR."
          }
        }
      ]
    },
    {
      "name": "Sessions  Student Booking",
      "item": [
        {
          "name": "Book Session (Student)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"mentorId\": {{mentor_id}},\n  \"subjectId\": {{subject_id}},\n  \"sessionAt\": \"2026-06-01T10:00:00.000Z\",\n  \"durationMinutes\": 60,\n  \"sessionType\": \"INDIVIDUAL\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions/book",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "book"]
            },
            "description": "Student self-books a session. sessionType: INDIVIDUAL | GROUP. Role: ADMIN | STUDENT."
          }
        },
        {
          "name": "Get Sessions by Student",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/sessions/student/{{student_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "student", "{{student_id}}"]
            },
            "description": "Role: ADMIN | STUDENT."
          }
        },
        {
          "name": "Submit Payment Receipt",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiptUrl\": \"https://res.cloudinary.com/demo/image/upload/receipt.jpg\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/sessions/{{session_id}}/submit-receipt",
              "host": ["{{base_url}}"],
              "path": ["api", "sessions", "{{session_id}}", "submit-receipt"]
            },
